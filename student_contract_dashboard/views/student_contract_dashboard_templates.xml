<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="dashboard_bi_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <div class="o_content">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-12">
                                <iframe
                                    t-att-src="dashboard_url"
                                    frameborder="0"
                                    style="width:100%; height:85vh;"
                                    >
                                </iframe>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <record id="action_open_powerbi_dashboard" model="ir.actions.act_url">
        <field name="name">Dashboard Student Contract</field>
        <field name="url">/student_contract_dashboard</field>
        <field name="target">self</field>
    </record>

    <menuitem id="menu_student_contract_dashboard_bi"
        name="Dashboard Student Contract"
        parent="student_contract_dashboard.menu_student_contract_dashboard"
        action="action_open_powerbi_dashboard"
        groups="student_contract_dashboard.group_student_contract_dashboard"
        sequence="1"/>
</odoo>
