<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_student_contract" model="ir.module.category">
            <field name="name">Student Contract</field>
            <field name="sequence">20</field>
            <field name="parent_id" ref="base.module_category_services"/>
        </record>

        <record id="group_student_contract_student" model="res.groups">
            <field name="name">Student</field>
            <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
            <field name="category_id" ref="module_category_student_contract"/>
        </record>

        <record id="group_student_contract_user" model="res.groups">
            <field name="name">User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="category_id" ref="module_category_student_contract"/>
        </record>

        <record id="group_student_contract_manager" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_student_contract"/>
            <field name="implied_ids" eval="[(4, ref('group_student_contract_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
