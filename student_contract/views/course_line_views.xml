<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_course_line_list" model="ir.ui.view">
        <field name="name">view.course.line.list</field>
        <field name="model">course.line</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="name" column_invisible="1"/>
                <field name="course_id" required="1" options="{'no_create': True,}"/>
                <field name="subject_ids" required="1" widget="many2many_tags" domain="[('id', 'in', domain_subject_ids)]" options="{'no_create': True,}"/>
                <field name="teacher_id" column_invisible="1"/>
            </list>
        </field>
    </record>
</odoo>
